{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sealstar-homepage",
  "compatibility_date": "2026-07-15",
  "main": "src/worker.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*", "/news", "/news.html", "/news/*"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
